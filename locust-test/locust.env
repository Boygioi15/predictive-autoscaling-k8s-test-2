PRIME_USER_WEIGHT=5
TEXT_USER_WEIGHT=0

PRIME_RANGE_MIN=1
PRIME_RANGE_MAX=1
PRIME_KTH_MIN=1
PRIME_KTH_MAX=1
PRIME_CHECK_MIN=1
PRIME_CHECK_MAX=1


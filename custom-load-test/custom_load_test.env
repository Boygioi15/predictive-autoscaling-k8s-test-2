TARGET_HOST=http://silkeste.fun
SCRIPT_CSV_PATH=/mnt/shares/test_script.csv
REQUEST_REPORT_PATH=/mnt/shares/load_test_request_report.csv
STATISTICS_REPORT_PATH=/mnt/shares/load_test_statistics_report.csv
METADATA_PATH=/mnt/shares/load_test_metadata.csv

SCRIPT_DISPATCH_MODE=spread
MAX_INFLIGHT=2000
REQUEST_TIMEOUT_SECONDS=0.2
CONNECT_TIMEOUT_SECONDS=0.2
PROGRESS_LOG_INTERVAL_SEC=1
REQUEST_LOG_FLUSH_INTERVAL_SEC=60
REQUEST_RESPONSE_MODE=close
REQUEST_SSL_VERIFY=true
SCRIPT_RANDOM_SEED=42

PRIME_BASE_PATH=/api/prime
TEXT_BASE_PATH=/api/text
TEXT_TRANSFORM_ROUNDS=50 

PRIME_USER_WEIGHT=5
TEXT_USER_WEIGHT=0

PRIME_RANGE_MIN=1
PRIME_RANGE_MAX=1
PRIME_KTH_MIN=1
PRIME_KTH_MAX=1
PRIME_CHECK_MIN=1
PRIME_CHECK_MAX=1

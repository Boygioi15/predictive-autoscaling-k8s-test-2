TARGET_HOST=149.28.152.134
SCRIPT_CSV_PATH=/app/scripts/test_script.csv
REQUEST_REPORT_PATH=/app/output/load_test_request_report.csv
STATISTICS_REPORT_PATH=/app/output/load_test_statistics_report.csv
INCIDENT_REPORT_PATH=/app/output/load_test_incident_report.csv
METADATA_PATH=/app/output/load_test_metadata.csv

SCRIPT_DISPATCH_MODE=spread
WORKER_COUNT=8
MAX_INFLIGHT=1000
BACKLOG_CAPACITY=1000
BACKLOG_MAX_AGE_SECONDS=5

REQUEST_TIMEOUT_SECONDS=10
CONNECT_TIMEOUT_SECONDS=10
PROGRESS_LOG_INTERVAL_SEC=1
REQUEST_LOG_FLUSH_INTERVAL_SEC=60
REQUEST_RESPONSE_MODE=close
REQUEST_SSL_VERIFY=true
SCRIPT_RANDOM_SEED=42

PRIME_BASE_PATH=/api/prime
TEXT_BASE_PATH=/api/text
TEXT_TRANSFORM_ROUNDS=50 

PRIME_USER_WEIGHT=5
TEXT_USER_WEIGHT=0

# Optional per-endpoint weights. If unset, each request inherits its user-group weight.
PRIME_RANGE_WEIGHT=5
PRIME_KTH_WEIGHT=3
PRIME_CHECK_WEIGHT=1

# PRIME_RANGE_MIN=1
# PRIME_RANGE_MAX=1
# PRIME_KTH_MIN=1
# PRIME_KTH_MAX=1
# PRIME_CHECK_MIN=1
# PRIME_CHECK_MAX=1
# EQUAL, UNIFORM, NORMAL
DISTRIBUTION_MODE=NORMAL

#EQUAL - 30ms
PRIME_RANGE_=400000
PRIME_KTH=35000
PRIME_CHECK=100000000


#UNIFORM 
#min-15ms, max-60ms
PRIME_RANGE_MIN=200000
PRIME_RANGE_MAX=600000
PRIME_KTH_MIN=20000
PRIME_KTH_MAX=45000
PRIME_CHECK_MIN=50000000
PRIME_CHECK_MAX=1000000000

#NORMAL
PRIME_RANGE_MIN=150000
PRIME_RANGE_MAX=550000
PRIME_RANGE_MEAN=350000
PRIME_RANGE_STANDARD=70000

PRIME_KTH_MIN=17000
PRIME_KTH_MAX=42000
PRIME_KTH_MEAN=25000
PRIME_KTH_STANDARD=8000

PRIME_CHECK_MIN=50000000
PRIME_CHECK_MAX=1000000000
PRIME_CHECK_MEAN=75000000
PRIME_CHECK_STANDARD=1000000

TARGET_HOST=http://149.28.141.66
SCRIPT_CSV_PATH=/app/scripts/test-script.csv
REQUEST_REPORT_PATH=/app/output/load_generator_request_report.csv
STATISTICS_REPORT_PATH=/app/output/load_generator_statistics_report.csv
INCIDENT_REPORT_PATH=/app/output/load_generator_incident_report.csv
METADATA_PATH=/app/output/load_generator_metadata.csv

SCRIPT_DISPATCH_MODE=spread
WORKER_COUNT=8
MAX_INFLIGHT=1000
BACKLOG_CAPACITY=1000
BACKLOG_MAX_AGE_SECONDS=5

REQUEST_TIMEOUT_SECONDS=10
CONNECT_TIMEOUT_SECONDS=10
PROGRESS_LOG_INTERVAL_SEC=1
REQUEST_LOG_FLUSH_INTERVAL_SEC=60
REQUEST_RESPONSE_MODE=close
REQUEST_SSL_VERIFY=true
SCRIPT_RANDOM_SEED=42

DEMAND_BASE_PATH=/demand
# Each second walks this list in order and wraps around if the second has more requests than classes.
REQUEST_CLASSES=directory,image,html,other,audio,java,video,compressed,dynamic

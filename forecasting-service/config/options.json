{
  "prime-last-value-v1": {
    "target_metric": "requests_per_minute",
    "feature_metrics": [
      "rps"
    ],
    "guardrail_queries": {
      "app_p95_seconds": "histogram_quantile(0.95, sum by (le) (rate(http_request_duration_seconds_bucket{service=\"{{deployment}}\"}[1m])))",
      "ingress_p95_seconds": "histogram_quantile(0.95, sum by (le) (rate(nginx_ingress_controller_request_duration_seconds_bucket{ingress=\"ingress-backend\"}[1m])))"
    },
    "lookback_steps": 60,
    "horizon_steps": 5,
    "step_seconds": 60,
    "model_full_name": "last_value:v1",
    "prometheus_queries": {
      "rps": "sum(increase(http_requests_total{job=\"{{deployment}}\"}[1m]))"
    },
    "local": true
  },
  "prime-linear-regression-v1": {
    "target_metric": "requests_per_minute",
    "feature_metrics": [
      "rps"
    ],
    "guardrail_queries": {
      "app_p95_seconds": "histogram_quantile(0.95, sum by (le) (rate(http_request_duration_seconds_bucket{service=\"{{deployment}}\"}[1m])))",
      "ingress_p95_seconds": "histogram_quantile(0.95, sum by (le) (rate(nginx_ingress_controller_request_duration_seconds_bucket{ingress=\"ingress-backend\"}[1m])))"
    },
    "lookback_steps": 60,
    "horizon_steps": 5,
    "step_seconds": 60,
    "model_full_name": "linear_regression:v1",
    "prometheus_queries": {
      "rps": "sum(increase(http_requests_total{job=\"{{deployment}}\"}[1m]))"
    },
    "local": false,
    "endpoint": "http://linear-regression-model.default.svc.cluster.local/predict"
  }
}
